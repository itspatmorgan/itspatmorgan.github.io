---
interface Props {
  src: string;
  title: string;
  caption?: string;
}

const { src, title, caption } = Astro.props;
---

<div class="figma-embed my-8">
  <div class="aspect-video overflow-hidden rounded-lg border border-border bg-card">
    <iframe
      src={src}
      title={title}
      class="h-full w-full"
      allowfullscreen
      loading="lazy"
    ></iframe>
  </div>
  {caption && (
    <p class="mt-3 text-center font-mono text-xs text-muted-foreground">
      {caption}
    </p>
  )}
</div>
