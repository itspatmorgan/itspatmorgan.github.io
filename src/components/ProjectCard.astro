---
import { Badge } from "@/components/ui/badge";

interface Props {
  title: string;
  description: string;
  skills: string[];
  thumbnail: string;
  thumbnailDark?: string;
  thumbnailWide?: string;
  thumbnailWideDark?: string;
  slug: string;
  impact?: string;
  index?: number;
  variant?: "full" | "compact";
  icon?: string;
}

const {
  title,
  description,
  skills,
  thumbnail,
  thumbnailDark,
  thumbnailWide,
  thumbnailWideDark,
  slug,
  impact,
  index = 0,
  variant = "full",
  icon,
} = Astro.props;

const isReversed = variant === "full" && index % 2 === 1;
---

{variant === "full" ? (
  <a href={`/projects/${slug}`} class="group block" data-project-card>
    <article class="overflow-hidden rounded-xl border border-border bg-card transition-all duration-300 group-hover:-translate-y-1 group-hover:shadow-lg group-hover:shadow-black/5 dark:group-hover:shadow-black/20">
      <div class={`flex flex-col ${isReversed ? "md:flex-row-reverse" : "md:flex-row"}`}>
        <div class="texture-bg overflow-hidden md:w-[40%]">
          {/* Mobile: wide image (16:9), hidden on md+ */}
          {thumbnailWide && (
            <img
              src={thumbnailWide}
              alt={title}
              class:list={["aspect-video w-full object-cover transition-transform duration-300 group-hover:scale-[1.03] md:hidden", thumbnailWideDark && "dark:hidden"]}
            />
          )}
          {thumbnailWide && thumbnailWideDark && (
            <img
              src={thumbnailWideDark}
              alt={title}
              class="hidden aspect-video w-full object-cover transition-transform duration-300 group-hover:scale-[1.03] dark:block md:dark:hidden"
            />
          )}
          {/* Desktop: square image, hidden below md */}
          <img
            src={thumbnail}
            alt={title}
            class:list={[thumbnailWide ? "hidden md:block" : "", "w-full object-cover transition-transform duration-300 group-hover:scale-[1.03] md:h-full", thumbnailDark && "dark:hidden"]}
          />
          {thumbnailDark && (
            <img
              src={thumbnailDark}
              alt={title}
              class:list={["w-full object-cover transition-transform duration-300 group-hover:scale-[1.03] md:h-full", thumbnailWide ? "hidden md:dark:block" : "hidden dark:block"]}
            />
          )}
        </div>
        <div class="flex flex-1 flex-col justify-center p-6">
          <h3 class="mb-3 text-lg font-semibold tracking-tight">
            {title}
          </h3>
          <div class="mb-3 flex flex-wrap gap-1.5">
            {skills.map((skill) => (
              <Badge variant="secondary" className="text-[11px]">{skill}</Badge>
            ))}
          </div>
          <p class="text-sm leading-relaxed text-muted-foreground">
            {description}
          </p>
          {impact && (
            <blockquote class="mt-4 border-l-2 border-accent pl-3 text-sm font-medium text-foreground">
              {impact}
            </blockquote>
          )}
        </div>
      </div>
    </article>
  </a>
) : (
  <a href={`/projects/${slug}`} class="group block" data-project-card>
    <article class="overflow-hidden rounded-xl border border-border bg-card transition-all duration-300 group-hover:-translate-y-0.5 group-hover:shadow-md group-hover:shadow-black/5 dark:group-hover:shadow-black/20">
      <div class="texture-bg overflow-hidden">
        <img
          src={thumbnail}
          alt={title}
          class:list={["aspect-video w-full object-cover transition-transform duration-300 group-hover:scale-[1.03]", thumbnailDark && "dark:hidden"]}
        />
        {thumbnailDark && (
          <img
            src={thumbnailDark}
            alt={title}
            class="hidden aspect-video w-full object-cover transition-transform duration-300 group-hover:scale-[1.03] dark:block"
          />
        )}
      </div>
      <div class="p-4">
        <div class="mb-2 flex items-center gap-2">
          {icon && (
            <img
              src={icon}
              alt=""
              class="logo-adaptive h-5 w-5 shrink-0"
            />
          )}
          <h3 class="text-base font-semibold tracking-tight">
            {title}
          </h3>
        </div>
        <div class="flex flex-wrap gap-1.5">
          {skills.map((skill) => (
            <Badge variant="secondary" className="text-[11px]">{skill}</Badge>
          ))}
        </div>
      </div>
    </article>
  </a>
)}
