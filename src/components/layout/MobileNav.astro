---
import { siteConfig } from "@/data/site-config";
import Logo from "./Logo.astro";

const elsewhere = [
  { label: "Substack", href: siteConfig.social.newsletter },
  { label: "LinkedIn", href: siteConfig.social.linkedin },
  { label: "X", href: siteConfig.social.x },
  { label: "GitHub", href: siteConfig.social.github },
];
---

<div
  id="mobile-nav"
  class="fixed inset-0 z-[100] bg-background flex flex-col md:hidden"
  style="display: none;"
  data-state="closed"
  aria-modal="true"
  role="dialog"
  aria-label="Navigation"
>
  {/* Top bar */}
  <div class="flex h-14 items-center justify-between px-4 border-b border-border shrink-0">
    <a href="/" class="block no-underline" aria-label="Home">
      <Logo />
    </a>
    <button
      id="mobile-nav-close"
      class="h-9 w-9 flex items-center justify-center text-muted-foreground hover:text-foreground transition-colors"
      aria-label="Close navigation"
    >
      <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  {/* Main nav */}
  <nav class="flex-1 flex flex-col justify-center px-8" aria-label="Main navigation">
    <ul class="flex flex-col">
      {siteConfig.nav.map((item) => (
        <li data-mobile-nav-item>
          <a
            href={item.href}
            class="block border-b border-border/50 py-3 text-[1.65rem] font-medium leading-tight text-muted-foreground transition-colors hover:text-foreground last:border-0"
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>

  {/* Elsewhere */}
  <div class="px-8 py-6 border-t border-border shrink-0" data-mobile-nav-elsewhere>
    <ul class="grid grid-cols-2 gap-x-6 gap-y-4">
      {elsewhere.map((item) => (
        <li>
          <a
            href={item.href}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 py-1 text-base text-muted-foreground transition-colors hover:text-foreground"
          >
            {item.label}
            <svg class="h-3.5 w-3.5 shrink-0 opacity-50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M7 17L17 7M7 7h10v10"/>
            </svg>
          </a>
        </li>
      ))}
    </ul>
  </div>
</div>

<style>
  #mobile-nav {
    opacity: 0;
    transition: opacity 160ms ease-out;
  }

  #mobile-nav[data-state="open"] {
    opacity: 1;
  }

  #mobile-nav[data-state="closing"] {
    opacity: 0;
    transition-duration: 120ms;
  }

  #mobile-nav [data-mobile-nav-item],
  #mobile-nav [data-mobile-nav-elsewhere] {
    opacity: 0;
    transform: translateY(10px);
    transition:
      opacity 220ms ease-out,
      transform 220ms ease-out;
  }

  #mobile-nav[data-state="open"] [data-mobile-nav-item],
  #mobile-nav[data-state="open"] [data-mobile-nav-elsewhere] {
    opacity: 1;
    transform: translateY(0);
  }

  #mobile-nav[data-state="open"] [data-mobile-nav-item]:nth-child(1) {
    transition-delay: 40ms;
  }

  #mobile-nav[data-state="open"] [data-mobile-nav-item]:nth-child(2) {
    transition-delay: 80ms;
  }

  #mobile-nav[data-state="open"] [data-mobile-nav-item]:nth-child(3) {
    transition-delay: 120ms;
  }

  #mobile-nav[data-state="open"] [data-mobile-nav-item]:nth-child(4) {
    transition-delay: 160ms;
  }

  #mobile-nav[data-state="open"] [data-mobile-nav-item]:nth-child(5) {
    transition-delay: 200ms;
  }

  #mobile-nav[data-state="open"] [data-mobile-nav-item]:nth-child(6) {
    transition-delay: 240ms;
  }

  #mobile-nav[data-state="open"] [data-mobile-nav-elsewhere] {
    transition-delay: 260ms;
  }

  #mobile-nav[data-state="closing"] [data-mobile-nav-item],
  #mobile-nav[data-state="closing"] [data-mobile-nav-elsewhere] {
    opacity: 0;
    transform: translateY(4px);
    transition-delay: 0ms;
    transition-duration: 100ms;
  }

  @media (prefers-reduced-motion: reduce) {
    #mobile-nav,
    #mobile-nav [data-mobile-nav-item],
    #mobile-nav [data-mobile-nav-elsewhere] {
      transition: none;
      transform: none;
    }
  }
</style>

<script>
  function initMobileNav() {
    const toggle = document.getElementById("mobile-nav-toggle");
    const close = document.getElementById("mobile-nav-close");
    const nav = document.getElementById("mobile-nav");
    if (!nav || nav.dataset.initialized === "true") return;
    nav.dataset.initialized = "true";
    let closeTimer: number | undefined;

    function open() {
      if (!nav) return;
      window.clearTimeout(closeTimer);
      nav.style.display = "flex";
      nav.dataset.state = "opening";
      document.body.style.overflow = "hidden";
      window.requestAnimationFrame(() => {
        nav.dataset.state = "open";
      });
    }

    function closeNav() {
      if (!nav) return;
      if (nav.dataset.state === "closed") return;
      window.clearTimeout(closeTimer);
      nav.dataset.state = "closing";
      document.body.style.overflow = "";
      closeTimer = window.setTimeout(() => {
        nav.style.display = "none";
        nav.dataset.state = "closed";
      }, 140);
    }

    toggle?.addEventListener("click", open);
    close?.addEventListener("click", closeNav);
    nav?.querySelectorAll("a").forEach((link) => link.addEventListener("click", closeNav));
    document.addEventListener("keydown", (e) => { if (e.key === "Escape") closeNav(); });
  }

  initMobileNav();
  document.addEventListener("astro:after-swap", initMobileNav);
</script>
