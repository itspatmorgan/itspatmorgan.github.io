---
import { siteConfig } from "@/data/site-config";
import { ThemeToggle } from "./ThemeToggle";
import { Badge } from "@/components/ui/badge";
---

<header class="sticky top-0 z-50 border-b border-border bg-background/80 backdrop-blur-sm">
  <nav class="mx-auto flex h-14 max-w-3xl items-center justify-between px-6">
    <a href="/" class="font-mono text-sm font-medium tracking-tight">
      {siteConfig.name}
    </a>

    <div class="flex items-center gap-4">
      {siteConfig.nav.map((link) => (
        <a
          href={link.href}
          class="text-sm text-muted-foreground transition-colors hover:text-foreground"
        >
          {link.label}
        </a>
      ))}
      <Badge variant="outline" className="hidden sm:inline-flex text-xs">
        Available for hire
      </Badge>
      <ThemeToggle client:load />
    </div>
  </nav>
</header>
