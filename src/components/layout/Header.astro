---
import Logo from "./Logo.astro";
import { ThemeToggle } from "./ThemeToggle";
---

<header class="md:hidden sticky top-0 z-50 border-b border-border bg-background/80 backdrop-blur-sm">
  <div class="flex h-14 items-center justify-between px-4">
    <a href="/" class="block no-underline" aria-label="Home">
      <Logo />
    </a>
    <div class="flex items-center gap-1">
      <ThemeToggle client:load />
      <button
        id="mobile-nav-toggle"
        class="h-8 w-8 flex items-center justify-center text-muted-foreground hover:text-foreground transition-colors"
        aria-label="Open navigation"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>
</header>
