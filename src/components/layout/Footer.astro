---
import { LocalTime } from "@/components/LocalTime";
---

<footer class="py-8 sm:py-10">
  <div class="mx-auto flex w-full max-w-[1400px] items-center justify-between px-6 sm:px-8 lg:px-14">
    <a
      href="/colophon"
      class="font-mono text-[10px] uppercase tracking-widest text-muted-foreground/60 transition-colors hover:text-foreground"
    >
      Colophon
    </a>
    <div class="flex items-center gap-3 whitespace-nowrap font-mono text-[10px] uppercase tracking-widest text-muted-foreground/50">
      <span>&copy; {new Date().getFullYear()}</span>
      {/* Sidebar already shows local time on desktop. */}
      <span class="md:hidden">
        <LocalTime compact client:load />
      </span>
    </div>
  </div>
</footer>
