---
import PixelWaveText from "@/components/PixelWaveText.astro";
import { GenerativeCanvas } from "@/lab/editorial-art/GenerativeCanvas";
import { brand } from "@/lab/editorial-art/themes";

interface Props {
  preview: string;
  title: string;
}

const { preview, title } = Astro.props;

const editorialPreview = {
  type: "strange-attractor",
  seed: 42,
  opacity: 85,
  color: "copper",
} as const;
---

<div class="relative aspect-[1200/630] overflow-hidden bg-card texture-bg">
  {preview === "editorial-art" && (
    <div class="absolute inset-0 bg-[#171716]">
      <GenerativeCanvas config={editorialPreview} bgColor={brand.warmDarkGray} animate client:load />
      <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-[#171716]/95 via-[#171716]/15 to-transparent"></div>
      <div class="pointer-events-none absolute bottom-4 left-4 right-4 flex flex-wrap items-center gap-x-3 gap-y-1 font-mono text-[10px] uppercase tracking-widest text-[#ede9e3]/70">
        <span>Strange Attractor</span>
        <span class="text-[#ede9e3]/35">Seed 42</span>
        <span class="text-[#ede9e3]/35">Opacity 85</span>
        <span class="text-[#ede9e3]/35">Copper</span>
      </div>
    </div>
  )}

  {preview === "pixel-wave" && (
    <div class="flex h-full items-center justify-center bg-background px-6 text-center">
      <PixelWaveText
        text="Pixel Wave Animation"
        as="p"
        wave="preview-pixel-wave"
        class="max-w-md text-3xl font-medium leading-tight tracking-tight sm:text-4xl"
      />
      <div class="pointer-events-none absolute inset-x-6 bottom-6 h-px bg-gradient-to-r from-transparent via-border to-transparent"></div>
    </div>
  )}

  {preview !== "editorial-art" && preview !== "pixel-wave" && (
    <div class="flex h-full items-center justify-center px-6 text-center">
      <p class="font-mono text-xs uppercase tracking-widest text-muted-foreground">{title}</p>
    </div>
  )}
</div>
