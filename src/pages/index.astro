---
import PageLayout from "@/layouts/PageLayout.astro";
import LogoCarousel from "@/components/LogoCarousel.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import { siteConfig } from "@/data/site-config";
import { homeCommendations } from "@/data/commendations";
import { getCollection } from "astro:content";

const allProjects = await getCollection("projects", ({ data }) => !data.draft);
const blogPosts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedDate.getTime() - a.data.publishedDate.getTime());
const professionalProjects = allProjects
  .filter((p) => p.data.type === "professional")
  .sort((a, b) => a.data.sortOrder - b.data.sortOrder);
const experimentProjects = allProjects
  .filter((p) => p.data.type === "experiment")
  .sort((a, b) => a.data.sortOrder - b.data.sortOrder);

const impactStatements: Record<string, string> = {
  "query-language": "Reduced new users' time to build a custom query from 21 days to 1.",
  "expansion": "Established scalable product architecture that enabled rapid market expansion.",
  "vision": "Unified product teams around a shared vision driven by customer insights.",
};
---

<PageLayout>
  {/* Hero */}
  <section class="mx-auto max-w-3xl px-6 pt-24 pb-12">
    <div class="mb-8 flex items-start gap-6">
      <img
        src="/images/brand/profile-picture.jpg"
        alt="Patrick Morgan"
        class="h-20 w-20 rounded-full object-cover"
      />
      <div>
        <p class="mb-1 font-mono text-sm text-muted-foreground">Product Designer</p>
        <h1 class="text-4xl font-medium tracking-tight sm:text-5xl">Patrick Morgan</h1>
      </div>
    </div>
    <p class="mb-6 max-w-xl text-lg text-muted-foreground">
      Product designer crafting intuitive experiences for high-impact technology. Building AI-powered tools at
      <a href="https://sublime.security" target="_blank" rel="noopener noreferrer" class="text-foreground underline underline-offset-4 transition-colors hover:text-accent">Sublime Security</a>.
      Writing
      <a href={siteConfig.social.newsletter} target="_blank" rel="noopener noreferrer" class="text-foreground underline underline-offset-4 transition-colors hover:text-accent">Unknown Arts</a>
      — a field guide for creative builders exploring AI and the creative frontier.
    </p>
    <div class="flex items-center gap-4 text-sm text-muted-foreground">
      <a
        href={siteConfig.social.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="transition-colors hover:text-foreground"
      >
        LinkedIn
      </a>
      <a
        href={siteConfig.social.newsletter}
        target="_blank"
        rel="noopener noreferrer"
        class="transition-colors hover:text-foreground"
      >
        Newsletter
      </a>
      <a
        href={siteConfig.social.x}
        target="_blank"
        rel="noopener noreferrer"
        class="transition-colors hover:text-foreground"
      >
        X
      </a>
    </div>
  </section>

  {/* Career Logos */}
  <section class="mx-auto max-w-3xl pb-16">
    <LogoCarousel />
  </section>

  {/* Product Design */}
  <section class="mx-auto max-w-3xl border-t border-border px-6 py-16">
    <h2 class="mb-8 font-mono text-xs uppercase tracking-widest text-muted-foreground">
      Product Design
    </h2>
    <div class="flex flex-col gap-10">
      {professionalProjects.map((project) => (
        <ProjectCard
          title={project.data.title}
          description={project.data.description}
          skills={project.data.skills}
          thumbnail={project.data.thumbnail}
          slug={project.id}
          impact={impactStatements[project.id]}
        />
      ))}
    </div>
  </section>

  {/* AI Experiments */}
  <section class="mx-auto max-w-3xl border-t border-border px-6 py-16">
    <h2 class="mb-8 font-mono text-xs uppercase tracking-widest text-muted-foreground">
      AI Experiments
    </h2>
    <div class="flex flex-col gap-10">
      {experimentProjects.map((project) => (
        <ProjectCard
          title={project.data.title}
          description={project.data.description}
          skills={project.data.skills}
          thumbnail={project.data.thumbnail}
          slug={project.id}
        />
      ))}
    </div>
  </section>

  {/* Unknown Arts */}
  <section class="mx-auto max-w-3xl border-t border-border px-6 py-16">
    <h2 class="mb-8 font-mono text-xs uppercase tracking-widest text-muted-foreground">
      Unknown Arts
    </h2>
    <div class="flex flex-col gap-6 sm:flex-row sm:gap-8">
      <div class="shrink-0 overflow-hidden rounded-lg border border-border sm:w-48">
        <img
          src="/images/unknown-arts/thumbnail.jpg"
          alt="Unknown Arts newsletter"
          class="aspect-square w-full object-cover"
        />
      </div>
      <div class="flex-1">
        <p class="mb-4 text-sm leading-relaxed text-muted-foreground">
          <a href={siteConfig.social.newsletter} target="_blank" rel="noopener noreferrer" class="text-foreground underline underline-offset-4 transition-colors hover:text-accent">Unknown Arts</a> is my weekly newsletter for creative builders exploring AI design and the creative frontier.
        </p>
        <div class="mb-4 grid grid-cols-3 gap-3">
          <div>
            <p class="text-lg font-semibold tracking-tight">7,400+</p>
            <p class="font-mono text-xs text-muted-foreground">Subscribers</p>
          </div>
          <div>
            <p class="text-lg font-semibold tracking-tight">190+</p>
            <p class="font-mono text-xs text-muted-foreground">Articles</p>
          </div>
          <div>
            <p class="text-lg font-semibold tracking-tight">128</p>
            <p class="font-mono text-xs text-muted-foreground">Countries</p>
          </div>
        </div>
        <p class="text-sm leading-relaxed text-muted-foreground">
          My writing has been featured in top publications like
          <a href="https://every.to" target="_blank" rel="noopener noreferrer" class="text-foreground underline underline-offset-4 transition-colors hover:text-accent">Every</a>,
          <a href="https://www.indiehackers.com" target="_blank" rel="noopener noreferrer" class="text-foreground underline underline-offset-4 transition-colors hover:text-accent">IndieHackers</a>,
          TLDR,
          <a href="https://www.departmentofproduct.com" target="_blank" rel="noopener noreferrer" class="text-foreground underline underline-offset-4 transition-colors hover:text-accent">The Department of Product</a>,
          <a href="https://uxdesign.cc" target="_blank" rel="noopener noreferrer" class="text-foreground underline underline-offset-4 transition-colors hover:text-accent">UX Collective</a>, and
          <a href="https://heydesigner.com" target="_blank" rel="noopener noreferrer" class="text-foreground underline underline-offset-4 transition-colors hover:text-accent">HeyDesigner</a>.
        </p>
      </div>
    </div>
  </section>

  {/* Writing Samples */}
  <section class="mx-auto max-w-3xl border-t border-border px-6 py-16">
    <h2 class="mb-8 font-mono text-xs uppercase tracking-widest text-muted-foreground">
      Writing Samples
    </h2>
    <div class="flex flex-col gap-6">
      {blogPosts.map((post) => (
        <a href={`/blog/${post.id}`} class="group block">
          <article class="flex items-baseline justify-between gap-4">
            <div class="min-w-0">
              <h3 class="mb-1 text-base font-semibold tracking-tight transition-colors group-hover:text-accent">
                {post.data.title}
              </h3>
              <p class="text-sm leading-relaxed text-muted-foreground">
                {post.data.description}
              </p>
            </div>
            <time
              datetime={post.data.publishedDate.toISOString()}
              class="shrink-0 font-mono text-xs text-muted-foreground"
            >
              {post.data.publishedDate.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}
            </time>
          </article>
        </a>
      ))}
    </div>
  </section>

  {/* Commendations */}
  <section class="mx-auto max-w-3xl border-t border-border px-6 py-16">
    <h2 class="mb-8 font-mono text-xs uppercase tracking-widest text-muted-foreground">
      Commendations
    </h2>
    <div class="grid gap-6 sm:grid-cols-2">
      {homeCommendations.map((c) => (
        <blockquote class="rounded-lg border border-border bg-card p-5">
          <p class="mb-3 text-sm leading-relaxed text-muted-foreground">
            "{c.quote}"
          </p>
          <footer class="text-sm">
            <span class="font-semibold">{c.name}</span>
            <span class="text-muted-foreground"> · {c.role}</span>
          </footer>
        </blockquote>
      ))}
    </div>
  </section>

  {/* CTA */}
  <section class="mx-auto max-w-3xl border-t border-border px-6 py-24 text-center">
    <h2 class="mb-6 text-3xl font-medium tracking-tight sm:text-4xl">
      Let's craft a better future, together.
    </h2>
    <div class="flex items-center justify-center gap-4 text-sm text-muted-foreground">
      <a
        href={siteConfig.social.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="transition-colors hover:text-foreground"
      >
        LinkedIn
      </a>
      <a
        href={siteConfig.social.newsletter}
        target="_blank"
        rel="noopener noreferrer"
        class="transition-colors hover:text-foreground"
      >
        Newsletter
      </a>
      <a
        href={siteConfig.social.x}
        target="_blank"
        rel="noopener noreferrer"
        class="transition-colors hover:text-foreground"
      >
        X
      </a>
    </div>
  </section>
</PageLayout>
