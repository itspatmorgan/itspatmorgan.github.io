---
import PageLayout from "@/layouts/PageLayout.astro";
import LogoCarousel from "@/components/LogoCarousel.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import { siteConfig } from "@/data/site-config";
import { commendations } from "@/data/commendations";
import { getCollection } from "astro:content";

const allProjects = await getCollection("projects", ({ data }) => !data.draft);
const writingPosts = (await getCollection("writing", ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedDate.getTime() - a.data.publishedDate.getTime());
const professionalProjects = allProjects
  .filter((p) => p.data.type === "professional")
  .sort((a, b) => a.data.sortOrder - b.data.sortOrder);
const experimentProjects = allProjects
  .filter((p) => p.data.type === "experiment")
  .sort((a, b) => a.data.sortOrder - b.data.sortOrder);

const experimentIcons: Record<string, string> = {
  "characters": "/images/logos/square-claude.svg",
  "gpts": "/images/logos/square-chatgpt.svg",
};

const impactStatements: Record<string, string> = {
  "query-language": "Reduced new users' time to build a custom query from 21 days to 1.",
  "expansion": "Established scalable product architecture that enabled rapid market expansion.",
  "vision": "Unified product teams around a shared vision driven by customer insights.",
};
---

<PageLayout>
  {/* Hero */}
  <section class="mx-auto max-w-3xl px-6 pt-24 pb-12">
    <div class="mb-8 flex items-start gap-6" data-hero-entrance style="opacity: 0;">
      <img
        src="/images/brand/profile-picture.jpg"
        alt="Patrick Morgan"
        class="h-20 w-20 rounded-full object-cover"
      />
      <div>
        <p class="mb-1 font-mono text-sm text-muted-foreground">Software Designer</p>
        <h1 class="text-4xl font-medium tracking-tight sm:text-5xl">Patrick Morgan</h1>
      </div>
    </div>
    <p class="mb-6 max-w-2xl text-md text-muted-foreground" data-hero-entrance style="opacity: 0;">
      Building AI-powered cybersecurity tools at
      <a href="https://sublime.security" target="_blank" rel="noopener noreferrer" class="text-foreground underline underline-offset-4 transition-colors hover:text-accent">Sublime Security</a> and writing
      <a href={siteConfig.social.newsletter} target="_blank" rel="noopener noreferrer" class="text-foreground underline underline-offset-4 transition-colors hover:text-accent">Unknown Arts</a>
      — a newsletter for builders exploring the creative frontier.
    </p>
    <div class="flex items-center gap-3 text-muted-foreground" data-hero-entrance style="opacity: 0;">
      <a
        href={siteConfig.social.newsletter}
        target="_blank"
        rel="noopener noreferrer"
        class="transition-colors hover:text-foreground"
        aria-label="Substack"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor"><path d="M20.6 8.242H1.46V5.406H20.6v2.836zM1.46 10.812V24l9.6-5.55 9.54 5.55V10.812H1.46zM20.6 0H1.46v2.836H20.6V0z"/></svg>
      </a>
      <a
        href={siteConfig.social.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="transition-colors hover:text-foreground"
        aria-label="LinkedIn"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
      </a>
      <a
        href={siteConfig.social.x}
        target="_blank"
        rel="noopener noreferrer"
        class="transition-colors hover:text-foreground"
        aria-label="X"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
      </a>
    </div>
  </section>

  {/* Career Logos */}
  <section class="mx-auto max-w-3xl pb-16">
    <LogoCarousel />
  </section>

  {/* Product Design */}
  <section class="mx-auto max-w-3xl border-t border-border px-6 py-16">
    <h2 class="mb-8 font-mono text-xs uppercase tracking-widest text-muted-foreground">
      Product Design
    </h2>
    <div class="flex flex-col gap-8">
      {professionalProjects.map((project, i) => (
        <div data-project-card-item style="opacity: 0;">
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            skills={project.data.skills}
            thumbnail={project.data.thumbnail}
            thumbnailDark={project.data.thumbnailDark}
            slug={project.id}
            impact={impactStatements[project.id]}
            index={i}
            variant="full"
          />
        </div>
      ))}
    </div>
  </section>

  {/* AI Experiments */}
  <section class="mx-auto max-w-3xl border-t border-border px-6 py-16">
    <h2 class="mb-8 font-mono text-xs uppercase tracking-widest text-muted-foreground">
      AI Experiments
    </h2>
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
      {experimentProjects.map((project, i) => (
        <div data-project-card-item style="opacity: 0;">
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            skills={project.data.skills}
            thumbnail={project.data.thumbnail}
            thumbnailDark={project.data.thumbnailDark}
            slug={project.id}
            index={i}
            variant="compact"
            icon={experimentIcons[project.id]}
          />
        </div>
      ))}
    </div>
  </section>

  {/* Writing */}
  <section class="mx-auto max-w-3xl border-t border-border px-6 py-16">
    <h2 class="mb-8 font-mono text-xs uppercase tracking-widest text-muted-foreground">
      Writing
    </h2>
    <div class="group mb-10 overflow-hidden rounded-lg border border-border">
      <div class="overflow-hidden">
        <img
          src="/images/unknown-arts/banner.webp"
          alt="Unknown Arts newsletter"
          class="w-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
          style="aspect-ratio: 16/7;"
        />
      </div>
      <div class="p-5 sm:p-6">
        <div class="mb-4 flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between sm:gap-8">
          <p class="text-sm leading-relaxed text-muted-foreground sm:flex-1">
            <a href={siteConfig.social.newsletter} target="_blank" rel="noopener noreferrer" class="text-foreground underline underline-offset-4 transition-colors hover:text-accent">Unknown Arts</a> is my weekly newsletter for creative builders exploring AI design and the creative frontier.
          </p>
          <div class="flex gap-6 sm:shrink-0">
            <div>
              <p class="text-lg font-semibold tracking-tight">7,400+</p>
              <p class="font-mono text-xs text-muted-foreground">Subscribers</p>
            </div>
            <div>
              <p class="text-lg font-semibold tracking-tight">190+</p>
              <p class="font-mono text-xs text-muted-foreground">Articles</p>
            </div>
            <div>
              <p class="text-lg font-semibold tracking-tight">128</p>
              <p class="font-mono text-xs text-muted-foreground">Countries</p>
            </div>
          </div>
        </div>
        <p class="text-sm leading-relaxed text-muted-foreground">
          Featured in
          <a href="https://every.to" target="_blank" rel="noopener noreferrer" class="text-foreground underline underline-offset-4 transition-colors hover:text-accent">Every</a>,
          <a href="https://www.indiehackers.com" target="_blank" rel="noopener noreferrer" class="text-foreground underline underline-offset-4 transition-colors hover:text-accent">IndieHackers</a>,
          <a href="https://tldr.tech/" target="_blank" rel="noopener noreferrer" class="text-foreground underline underline-offset-4 transition-colors hover:text-accent">TLDR</a>,
          <a href="https://www.departmentofproduct.com" target="_blank" rel="noopener noreferrer" class="text-foreground underline underline-offset-4 transition-colors hover:text-accent">The Department of Product</a>,
          <a href="https://uxdesign.cc" target="_blank" rel="noopener noreferrer" class="text-foreground underline underline-offset-4 transition-colors hover:text-accent">UX Collective</a>, and
          <a href="https://heydesigner.com" target="_blank" rel="noopener noreferrer" class="text-foreground underline underline-offset-4 transition-colors hover:text-accent">HeyDesigner</a>.
        </p>
      </div>
    </div>
    <div class="flex flex-col gap-6">
      {writingPosts.slice(0, 4).map((post) => (
        <a href={`/writing/${post.id}`} class="group block">
          <article class="flex items-baseline justify-between gap-4">
            <div class="min-w-0">
              <h3 class="mb-1 text-base font-semibold tracking-tight transition-colors group-hover:text-accent">
                {post.data.title}
              </h3>
              <p class="text-sm leading-relaxed text-muted-foreground">
                {post.data.description}
              </p>
            </div>
            <time
              datetime={post.data.publishedDate.toISOString()}
              class="shrink-0 font-mono text-xs text-muted-foreground"
            >
              {post.data.publishedDate.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}
            </time>
          </article>
        </a>
      ))}
    </div>
    <div class="mt-8 flex items-center gap-6 text-sm">
      <a href="/writing" class="transition-colors hover:text-accent">View all articles &rarr;</a>
      <a href={siteConfig.social.newsletter} target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-accent">Read the newsletter &rarr;</a>
    </div>
  </section>

  {/* Kind Words */}
  <section class="mx-auto max-w-3xl border-t border-border px-6 py-16">
    <h2 class="mb-8 font-mono text-xs uppercase tracking-widest text-muted-foreground">
      Kind Words
    </h2>
    <div class="columns-1 gap-4 sm:columns-2">
      {commendations.map((c) => (
        <blockquote class="mb-4 break-inside-avoid rounded-lg border border-border bg-card p-5" data-kind-words-item style="opacity: 0;">
          <div class="mb-3 flex items-center gap-3">
            <img
              src={c.image}
              alt={c.name}
              class="h-10 w-10 rounded-full object-cover"
            />
            <div>
              <p class="text-sm font-semibold leading-tight">{c.name}</p>
              <p class="text-xs text-muted-foreground">{c.role}</p>
            </div>
          </div>
          <p class="text-sm leading-relaxed text-muted-foreground">
            {c.quote}
          </p>
        </blockquote>
      ))}
    </div>
  </section>

  {/* CTA */}
  <section class="mx-auto max-w-3xl border-t border-border px-6 py-24 text-center">
    <p class="text-3xl font-medium tracking-tight sm:text-4xl">
      Let's craft a better future, together.
    </p>
  </section>

  <script>
    import { animate } from "motion";

    function init() {
      // Hero entrance: staggered spring-in on page load
      const heroEls = document.querySelectorAll('[data-hero-entrance]') as NodeListOf<HTMLElement>;
      heroEls.forEach((el, i) => {
        animate(
          el,
          { opacity: [0, 1], y: [16, 0] },
          { type: "spring", stiffness: 160, damping: 20, mass: 0.8, delay: i * 0.12 }
        );
      });

      // Scroll-triggered staggered entrance — groups items by their parent section
      function observeSections(selector: string, opts: { yOffset?: number; stagger?: number; threshold?: number } = {}) {
        const allItems = document.querySelectorAll(selector) as NodeListOf<HTMLElement>;
        if (!allItems.length) return;
        const { yOffset = 20, stagger = 0.08, threshold = 0.15 } = opts;

        // Group items by their closest section
        const sectionMap = new Map<Element, HTMLElement[]>();
        allItems.forEach((el) => {
          const section = el.closest('section');
          if (!section) return;
          if (!sectionMap.has(section)) sectionMap.set(section, []);
          sectionMap.get(section)!.push(el);
        });

        // Create an observer per section
        sectionMap.forEach((items, section) => {
          let revealed = false;
          const obs = new IntersectionObserver((entries) => {
            if (revealed) return;
            for (const entry of entries) {
              if (entry.isIntersecting) {
                revealed = true;
                obs.disconnect();
                items.forEach((el, i) => {
                  animate(
                    el,
                    { opacity: [0, 1], y: [yOffset, 0] },
                    { type: "spring", stiffness: 140, damping: 18, mass: 0.8, delay: i * stagger }
                  );
                });
                break;
              }
            }
          }, { threshold });
          obs.observe(section);
        });
      }

      // Project cards entrance (both Product Design and AI Experiments sections)
      observeSections('[data-project-card-item]', { yOffset: 24, stagger: 0.1 });

      // Kind Words entrance
      observeSections('[data-kind-words-item]', { yOffset: 20, stagger: 0.06 });
    }

    init();
    document.addEventListener('astro:after-swap', init);
  </script>
</PageLayout>
