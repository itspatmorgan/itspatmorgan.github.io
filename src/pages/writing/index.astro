---
import PageLayout from "@/layouts/PageLayout.astro";
import WordCarousel from "@/components/WordCarousel.astro";
import { siteConfig } from "@/data/site-config";
import { getCollection } from "astro:content";

const posts = (await getCollection("writing", ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedDate.getTime() - a.data.publishedDate.getTime());
---

<PageLayout title="Writing — Patrick Morgan" description="Articles on AI, design, and the creative frontier.">
  {/* Hero */}
  <section class="mx-auto max-w-3xl px-6 pt-24 pb-12">
    <h1 class="mb-4 text-4xl font-medium tracking-tight sm:text-5xl">Writing</h1>
    <p class="max-w-lg text-lg text-muted-foreground">
      Thoughts on AI, design, and the creative frontier. Subscribe to
      <a
        href={siteConfig.social.newsletter}
        target="_blank"
        rel="noopener noreferrer"
        class="text-foreground underline underline-offset-4 transition-colors hover:text-accent"
      >Unknown Arts</a> for weekly updates.
    </p>
  </section>

  {/* Word Carousel */}
  <section class="mx-auto max-w-3xl pb-12">
    <WordCarousel />
  </section>

  {/* Articles */}
  <section class="mx-auto max-w-3xl border-t border-border px-6 py-16 pb-24">
    <div class="flex flex-col gap-8">
      {posts.map((post) => (
        <a href={`/writing/${post.id}`} class="group block">
          <article class="flex gap-5">
            {post.data.image && (
              <div class="hidden shrink-0 overflow-hidden rounded-lg border border-border sm:block sm:w-36 md:w-44">
                <img
                  src={post.data.image}
                  alt=""
                  class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.03]"
                  loading="lazy"
                />
              </div>
            )}
            <div class="flex min-w-0 flex-1 flex-col justify-center">
              <time
                datetime={post.data.publishedDate.toISOString()}
                class="mb-1 font-mono text-xs text-muted-foreground"
              >
                {post.data.publishedDate.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}
              </time>
              <h2 class="mb-1 text-base font-semibold tracking-tight transition-colors group-hover:text-accent">
                {post.data.title}
              </h2>
              <p class="text-sm leading-relaxed text-muted-foreground">
                {post.data.description}
              </p>
            </div>
          </article>
        </a>
      ))}
    </div>
  </section>
</PageLayout>
