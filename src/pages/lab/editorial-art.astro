---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import MobileNav from '@/components/layout/MobileNav.astro';
import Sidebar from '@/components/layout/Sidebar.astro';
import EditorialArtTool from '@/lab/editorial-art/index';
import { getCollection } from "astro:content";

const entry = (await getCollection("lab")).find((item) => item.data.slug === "editorial-art");
---

<BaseLayout
  title={`${entry?.data.title ?? "Editorial Art Tool"} — Patrick Morgan`}
  description={entry?.data.description ?? "Generate editorial feature images for Unknown Arts articles."}
  noindex
>
  <Header />
  <MobileNav />
  <div class="md:flex md:min-h-screen">
    <Sidebar />
    <main class="min-w-0 flex-1">
      <div class="lab-tool-fade">
        <EditorialArtTool client:only="react" />
      </div>
    </main>
  </div>
</BaseLayout>

<style>
  .lab-tool-fade {
    animation: lab-tool-in 0.5s ease-out both;
  }

  @keyframes lab-tool-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .lab-tool-fade { animation: none; }
  }
</style>
