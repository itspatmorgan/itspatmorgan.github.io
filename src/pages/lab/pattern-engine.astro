---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import PatternEngine from '@/lab/editorial-art/index';
import { getCollection } from "astro:content";

const entry = (await getCollection("lab")).find((item) => item.data.slug === "pattern-engine");
---

<BaseLayout
  title={`${entry?.data.title ?? "Pattern Engine"} — Patrick Morgan`}
  description={entry?.data.description ?? "Generate deterministic visual patterns for Unknown Arts articles and publishing assets."}
  noindex
>
  <Header />
  <div class="lab-tool-fade">
    <PatternEngine client:load />
  </div>
</BaseLayout>

<style>
  .lab-tool-fade {
    animation: lab-tool-in 0.5s ease-out both;
  }

  @keyframes lab-tool-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .lab-tool-fade { animation: none; }
  }
</style>
