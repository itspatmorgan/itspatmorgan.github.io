---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import MobileNav from '@/components/layout/MobileNav.astro';
import Sidebar from '@/components/layout/Sidebar.astro';
import PatternEngine from '@/lab/editorial-art/index';
import { getCollection } from "astro:content";

const entry = (await getCollection("lab")).find((item) => item.data.slug === "pattern-engine");
---

<BaseLayout
  title={`${entry?.data.title ?? "Pattern Engine"} — Patrick Morgan`}
  description={entry?.data.description ?? "Generate deterministic visual patterns for Unknown Arts articles and publishing assets."}
  noindex
>
  <Header />
  <MobileNav />
  <div class="pattern-engine-shell md:flex md:min-h-dvh">
    <Sidebar />
    <main class="min-w-0 flex-1">
      <div class="lab-tool-fade">
        <PatternEngine client:only="react" />
      </div>
    </main>
  </div>
</BaseLayout>

<style>
  .pattern-engine-shell {
    --pattern-engine-height: calc(100dvh - 3.5rem);
  }

  .lab-tool-fade {
    min-height: var(--pattern-engine-height);
    animation: lab-tool-in 0.5s ease-out both;
  }

  @media (min-width: 48rem) {
    .pattern-engine-shell {
      --pattern-engine-height: 100dvh;
    }
  }

  @keyframes lab-tool-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .lab-tool-fade { animation: none; }
  }
</style>
