---
import PageLayout from "@/layouts/PageLayout.astro";
import LabCard from "@/components/lab/LabCard.astro";
import { getCollection } from "astro:content";

const preferredOrder = ["dot-mark", "editorial-art", "pixel-wave"];
const entries = (await getCollection("lab", ({ data }) => !data.draft))
  .sort((a, b) => {
    const aIndex = preferredOrder.indexOf(a.data.slug);
    const bIndex = preferredOrder.indexOf(b.data.slug);
    if (aIndex !== -1 || bIndex !== -1) {
      return (aIndex === -1 ? Number.MAX_SAFE_INTEGER : aIndex) - (bIndex === -1 ? Number.MAX_SAFE_INTEGER : bIndex);
    }
    return a.data.title.localeCompare(b.data.title);
  });
---

<PageLayout
  title="Lab — Patrick Morgan"
  description="Tools, experiments, and interaction showcases."
  noindex
>
  <section class="mx-auto max-w-3xl px-6 pt-12 pb-16 sm:pt-24 sm:pb-12">
    <h1 class="mb-4 text-4xl font-medium tracking-tight sm:text-5xl">Lab</h1>
    <p class="max-w-xl text-lg text-muted-foreground">
      A gallery of tools, experiments, and interactions I've built.
    </p>
  </section>

  <section class="mx-auto max-w-3xl border-t border-border px-6 py-16 pb-24">
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
      {entries.map((entry) => (
        <LabCard
          title={entry.data.title}
          description={entry.data.description}
          href={`/lab/${entry.data.slug}`}
          preview={entry.data.preview}
        />
      ))}
    </div>
  </section>
</PageLayout>

<script>
  import "@/scripts/lab-previews";
</script>
