---
import PageLayout from "@/layouts/PageLayout.astro";

const tools = [
  {
    title: "Editorial Art Tool",
    description: "Generate deterministic feature images for writing and publishing workflows.",
    href: "/tools/editorial-art",
    status: "Active",
  },
];
---

<PageLayout
  title="Tools — Patrick Morgan"
  description="Small tools built for my own creative and publishing workflows."
  noindex
>
  <section class="mx-auto max-w-3xl px-6 pt-12 pb-16 sm:pt-24 sm:pb-12">
    <h1 class="mb-4 text-4xl font-medium tracking-tight sm:text-5xl">Tools</h1>
    <p class="max-w-xl text-lg text-muted-foreground">
      A small shelf of utilities I have built for my own creative, publishing, and design workflows.
    </p>
  </section>

  <section class="mx-auto max-w-3xl border-t border-border px-6 py-16 pb-24">
    <div class="flex flex-col gap-2">
      {tools.map((tool) => (
        <a
          href={tool.href}
          class="group -mx-3 block rounded-lg p-3 transition-all duration-200 ease-out hover:scale-[1.01] hover:bg-muted/50"
        >
          <article class="flex items-start justify-between gap-5">
            <div class="min-w-0 flex-1">
              <h2 class="mb-1 text-base font-semibold tracking-tight transition-colors group-hover:text-accent">
                {tool.title}
              </h2>
              <p class="text-sm leading-relaxed text-muted-foreground">
                {tool.description}
              </p>
            </div>
            <span class="mt-0.5 shrink-0 rounded-full border border-border px-2 py-0.5 font-mono text-[10px] uppercase tracking-wide text-muted-foreground">
              {tool.status}
            </span>
          </article>
        </a>
      ))}
    </div>
  </section>
</PageLayout>
