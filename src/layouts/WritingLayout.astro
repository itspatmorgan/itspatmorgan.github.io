---
import PageLayout from "./PageLayout.astro";
import { Badge } from "@/components/ui/badge";

interface Props {
  title: string;
  description: string;
  publishedDate: Date;
  categories: string[];
}

const { title, description, publishedDate, categories } = Astro.props;
---

<PageLayout title={title} description={description}>
  <article class="mx-auto max-w-3xl px-6 py-16">
    {/* Back link */}
    <a
      href="/writing"
      class="mb-8 inline-flex items-center gap-1 font-mono text-sm text-muted-foreground transition-colors hover:text-foreground"
    >
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
      </svg>
      Writing
    </a>

    {/* Header */}
    <header class="mb-12">
      <h1 class="mb-4 text-4xl font-medium tracking-tight sm:text-5xl">
        {title}
      </h1>
      <div class="flex flex-wrap items-center gap-3">
        <time
          datetime={publishedDate.toISOString()}
          class="font-mono text-sm text-muted-foreground"
        >
          {publishedDate.toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" })}
        </time>
        {categories.length > 0 && (
          <>
            <span class="h-3.5 w-px bg-border" aria-hidden="true"></span>
            {categories.map((cat) => (
              <Badge variant="secondary" className="font-mono text-xs">
                {cat}
              </Badge>
            ))}
          </>
        )}
      </div>
    </header>

    {/* Markdown body */}
    <div class="prose">
      <slot />
    </div>
  </article>
</PageLayout>
