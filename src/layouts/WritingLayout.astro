---
import PageLayout from "./PageLayout.astro";
import { Badge } from "@/components/ui/badge";

interface Props {
  title: string;
  description: string;
  publishedDate: Date;
  theme?: string;
  image?: string;
  canonicalUrl?: string;
}

const { title, description, publishedDate, theme, image, canonicalUrl } = Astro.props;
---

<PageLayout title={title} description={description} canonicalUrl={canonicalUrl}>
  <article class="mx-auto max-w-3xl px-6 py-16">
    {/* Back link */}
    <a
      href="/writing"
      class="mb-8 inline-flex items-center gap-1 font-mono text-sm text-muted-foreground transition-colors hover:text-foreground"
    >
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
      </svg>
      Writing
    </a>

    {/* Header */}
    <header class="mb-12">
      <h1 class="mb-3 text-4xl font-medium tracking-tight sm:text-5xl">
        {title}
      </h1>
      <p class="mb-5 text-lg leading-snug text-muted-foreground">
        {description}
      </p>
      <div class="flex flex-wrap items-center gap-3">
        <time
          datetime={publishedDate.toISOString()}
          class="font-mono text-sm text-muted-foreground"
        >
          {publishedDate.toLocaleDateString("en-US", { timeZone: "UTC", month: "long", day: "numeric", year: "numeric" })}
        </time>
        {theme && (
          <>
            <span class="h-3.5 w-px bg-border" aria-hidden="true"></span>
            <Badge variant="secondary" className="font-mono text-xs">
              {theme}
            </Badge>
          </>
        )}
      </div>
    </header>

    {/* Hero image */}
    {image && (
      <figure class="mb-12">
        <div class="overflow-hidden rounded-lg border border-border">
          <img
            src={image}
            alt={title}
            class="w-full object-cover"
          />
        </div>
        <figcaption class="mt-2 font-mono text-xs text-muted-foreground">
          Image by Patrick Morgan, created with Midjourney
        </figcaption>
      </figure>
    )}

    {/* Markdown body */}
    <div class="prose">
      <slot />
    </div>
  </article>
</PageLayout>
